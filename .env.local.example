# PhysIQ Environment Variables
# Copy file này thành .env.local và điền thông tin Supabase của bạn

# ===========================================
# SUPABASE CONFIG
# ===========================================
# Lấy từ Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# APP CONFIG
# ===========================================
# Secret key để mã hóa license data (tạo chuỗi ngẫu nhiên 32+ ký tự)
LICENSE_SECRET_KEY=your-32-char-secret-key-here-change-this

# ===========================================
# ADMIN CONFIG  
# ===========================================
# Mật khẩu truy cập trang /admin
ADMIN_PASSWORD=change-this-admin-password

# Domain whitelist (nếu muốn giới hạn license chỉ chạy trên domain nhất định)
# Nhiều domain cách nhau bằng dấu phẩy
ALLOWED_DOMAINS=localhost,127.0.0.1

# ===========================================
# LICENSE CONFIG
# ===========================================
# Thời gian grace period khi offline (mili giây). Mặc định: 24h = 86400000
LICENSE_GRACE_PERIOD_MS=86400000

# Khoảng thời gian checkin (mili giây). Mặc định: 5 phút
LICENSE_CHECKIN_INTERVAL_MS=300000
